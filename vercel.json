{
  "version": 2,
  "functions": {
    "api/index.py": {
      "includeFiles": "Cau_hinh.xlsx"
    }
  },
  "rewrites": [
    {
      "source": "/process",
      "destination": "/api/index.py"
    },
    {
      "source": "/config",
      "destination": "/api/index.py"
    },
    {
      "source": "/ping",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
